// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  password      String
  streakDays    Int       @default(0) @map("streak_days")
  lastStudyDate DateTime? @map("last_study_date")

  subjects      Subject[]
  scheduleItems ScheduleItem[]
  reviews       Review[]

  createdAt DateTime @default(now()) @map("created_at")
}

enum SubjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

model Subject {
  id           String        @id @default(uuid())
  name         String
  description  String?
  hoursPerWeek Int           @default(0) @map("hours_per_week")
  status       SubjectStatus @default(ACTIVE)
  userId       String        @map("user_id")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  topics Topic[]

  createdAt DateTime @default(now()) @map("created_at")
}

enum TopicStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
  NEEDS_REVIEW
}

model Topic {
  id             String      @id @default(uuid())
  name           String
  description    String?
  estimatedHours Int         @map("estimated_hours")
  order          Int
  status         TopicStatus @default(NOT_STARTED)
  subjectId      String

  subject          Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  prerequisites    Topic[]        @relation("TopicPrerequisities")
  prerequisitesFor Topic[]        @relation("TopicPrerequisities")
  scheduleItems    ScheduleItem[]
  review           Review?

  createdAt DateTime @default(now()) @map("created_at")
}

enum ScheduleStatus {
  WAIT
  COMPLETED
}

model ScheduleItem {
  id           String         @id @default(uuid())
  topicId      String         @map("topic_id")
  userId       String         @map("user_id")
  scheduleDate DateTime       @map("schedule_date")
  status       ScheduleStatus @default(WAIT)

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
}

model Review {
  id             String   @id @default(uuid())
  topicId        String   @unique() @map("topic_id")
  userId         String   @map("user_id")
  easeFactor     Float    @default(2.5) @map("ease_factor")
  interval       Int      @default(1)
  repetitions    Int      @default(0)
  nextReviewDate DateTime @map("next_review_date")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
}
